{
  "name": "drun-language-support",
  "displayName": "Drun Language Support",
  "description": "Syntax highlighting and editor support for the Drun automation language.",
  "version": "0.0.1",
  "publisher": "phillarmonic",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "drun",
    "automation",
    "dsl",
    "textmate"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/phillarmonic/drun-vscode"
  },
  "scripts": {
    "build:grammar:compile": "tsc -p ./tsconfig.grammar.json",
    "build:grammar": "pnpm run build:grammar:compile && node ./.build/scripts/build-grammar.js",
    "compile": "pnpm run build:grammar",
    "validate:json": "pnpm run build:grammar && node ./.build/scripts/validate-json.js",
    "test:grammar": "pnpm run build:grammar && node ./.build/scripts/test-grammar.js",
    "test": "pnpm run validate:json && pnpm run test:grammar",
    "vscode:prepublish": "pnpm run compile",
    "package:vsix": "node ./scripts/package-vsix.js"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "typescript": "^5.8.3",
    "vscode-oniguruma": "^2.0.1",
    "vscode-textmate": "^9.2.0"
  },
  "contributes": {
    "languages": [
      {
        "id": "drun",
        "aliases": [
          "Drun",
          "drun"
        ],
        "extensions": [
          ".drun"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "drun",
        "scopeName": "source.drun",
        "path": "./syntaxes/drun.tmLanguage.json"
      }
    ]
  }
}
